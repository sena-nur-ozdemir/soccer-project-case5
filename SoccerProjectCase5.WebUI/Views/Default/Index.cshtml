@using SoccerProjectCase5.WebUI.Models.Enums
@model IndexFixtureViewModel

@{
    Layout = null;
    var random = new Random();
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GoalZone — Premier League</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
       
        :root {
            --bg: #0a0f1a;
            --bg2: #0f172a;
            --card: #1e293b;
            --card2: #273449;
            --elevated: #334155;
            --primary: #00e5ff;
            --secondary: #651fff;
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #f8fafc;
            --t2: #94a3b8;
            --t3: #64748b;
            --border: #334155;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: 'Barlow Condensed',sans-serif;
            --fb: 'Barlow',sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at 15% 0%,rgba(101,31,255,.07) 0%,transparent 55%), radial-gradient(ellipse at 85% 0%,rgba(0,229,255,.04) 0%,transparent 50%)
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: var(--bg)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--elevated);
            border-radius: 3px
        }

        a {
            text-decoration: none;
            color: inherit
        }

        img {
            display: block
        }

        /* ─── NAVBAR ─── */
        .nb {
            background: rgba(10,15,26,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5)
        }

        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0
        }

        .brand-ico {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg,var(--primary),var(--secondary));
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px
        }

        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px
        }

            .brand-txt span {
                color: var(--primary)
            }

        .nav-links {
            display: flex
        }

        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr)
        }

            .nl::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--primary);
                transform: scaleX(0);
                transition: var(--tr)
            }

            .nl:hover, .nl.active {
                color: var(--t1)
            }

                .nl:hover::after, .nl.active::after {
                    transform: scaleX(1)
                }

        .nb-icons {
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr)
        }

            .ico-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--secondary)
            }

        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1
        }

        .mob-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height .3s ease
        }

            .mob-menu.open {
                max-height: 320px
            }

            .mob-menu .nl {
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                display: block
            }

        .wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px
        }

        /* ─── LEAGUE HEADER ─── */
        .lg-head {
            background: linear-gradient(135deg,var(--bg2),var(--card));
            border-bottom: 1px solid var(--border);
            padding: 32px 0 24px;
            position: relative;
            overflow: hidden
        }

            .lg-head::before {
                content: '';
                position: absolute;
                top: -40%;
                right: -5%;
                width: 380px;
                height: 380px;
                background: radial-gradient(circle,rgba(0,229,255,.05) 0%,transparent 70%);
                pointer-events: none
            }

        .lg-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.22);
            border-radius: 20px;
            padding: 4px 12px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 10px
        }

        .lg-title {
            font-family: var(--fd);
            font-size: clamp(26px,5vw,42px);
            font-weight: 900;
            letter-spacing: .5px;
            line-height: 1
        }

        .lg-sub {
            font-size: 13px;
            color: var(--t2);
            margin-top: 6px
        }

        .lg-stats {
            display: flex;
            gap: 24px;
            align-items: flex-end;
            justify-content: flex-end;
            height: 100%
        }

        .ls-num {
            font-family: var(--fd);
            font-size: 30px;
            font-weight: 800;
            color: var(--primary);
            line-height: 1
        }

        .ls-lbl {
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 3px
        }

        /* ─── FILTER TABS ─── */
        .ftabs-wrap {
            background: var(--bg2);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 62px;
            z-index: 99
        }

        .ftabs {
            display: flex;
            overflow-x: auto;
            scrollbar-width: none
        }

            .ftabs::-webkit-scrollbar {
                display: none
            }

        .ftab {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--t3);
            padding: 15px 18px;
            cursor: pointer;
            border: none;
            background: transparent;
            border-bottom: 2px solid transparent;
            transition: var(--tr);
            white-space: nowrap
        }

            .ftab:hover {
                color: var(--t2);
                background: rgba(255,255,255,.02)
            }

            .ftab.active {
                color: var(--primary);
                border-bottom-color: var(--primary)
            }

        .live-dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            background: var(--live);
            border-radius: 50%;
            margin-right: 5px;
            animation: pdot 1.4s ease-in-out infinite
        }
        @@keyframes pdot {
            0%,100%

        {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: .4;
            transform: scale(.7)
        }

        }

        .bcnt {
            background: var(--live);
            color: #fff;
            border-radius: 9px;
            font-size: 10px;
            padding: 1px 6px;
            margin-left: 5px;
            font-weight: 700
        }

        /* ─── FEATURED CARD ─── */
        .feat-wrap {
            padding: 30px 0 6px
        }

        .feat-lbl {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px
        }

            .feat-lbl::before {
                content: '';
                display: inline-block;
                width: 18px;
                height: 2px;
                background: var(--primary)
            }

        .feat-card {
            background: linear-gradient(135deg,#0f172a 0%,#1e293b 50%,#0f172a 100%);
            border: 1px solid rgba(0,229,255,.2);
            border-radius: var(--r3);
            padding: 30px 36px;
            position: relative;
            overflow: hidden;
            transition: var(--tr);
            display: block;
            color: inherit
        }

            .feat-card:hover {
                border-color: rgba(0,229,255,.5);
                transform: translateY(-2px);
                box-shadow: 0 12px 44px rgba(0,0,0,.6);
                color: inherit
            }

            .feat-card::after {
                content: '★ HAFTANIN MAÇI';
                position: absolute;
                top: 14px;
                right: 18px;
                font-family: var(--fd);
                font-size: 9px;
                font-weight: 800;
                letter-spacing: 2px;
                color: var(--gold);
                background: rgba(255,214,0,.09);
                border: 1px solid rgba(255,214,0,.2);
                padding: 3px 10px;
                border-radius: 10px
            }

        .ft-team {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px
        }

        .ft-logo {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: var(--elevated);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 900;
            overflow: hidden
        }

            .ft-logo img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 6px
            }

        .ft-name {
            font-family: var(--fd);
            font-size: 18px;
            font-weight: 800;
            text-align: center
        }

        .ft-type {
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600
        }

        .ft-sc-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px
        }

        .ft-sc {
            font-family: var(--fd);
            font-size: clamp(48px,8vw,72px);
            font-weight: 900;
            letter-spacing: -3px;
            line-height: 1;
            background: linear-gradient(180deg,#fff 0%,#94a3b8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

        .ft-stat {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            color: var(--t3)
        }

        .ft-meta {
            font-size: 12px;
            color: var(--t2);
            text-align: center;
            margin-top: 4px
        }

        /* ─── SECTION TITLE ─── */
        .sec-ttl {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t3);
            padding: 14px 0 8px;
            border-top: 1px solid var(--border);
            margin-top: 8px;
            margin-bottom: 4px
        }

        /* ═══════════════════════════════════════════════
                   MATCH CARD
                   ═══════════════════════════════════════════════ */
        .mc-wrap {
            margin-bottom: 8px
        }

        .mc {
            width: 100%;
            display: flex;
            align-items: center;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 0 18px;
            min-height: 66px;
            overflow: hidden;
            transition: var(--tr);
            color: inherit;
        }

            .mc:hover {
                background: var(--card2);
                border-color: rgba(101,31,255,.3);
                transform: translateY(-1px);
                box-shadow: 0 6px 24px rgba(0,0,0,.4);
                color: inherit;
            }

            .mc.live {
                border-color: rgba(255,23,68,.22);
                background: linear-gradient(90deg,var(--card),rgba(255,23,68,.03))
            }

                .mc.live:hover {
                    border-color: rgba(255,23,68,.45)
                }

            .mc.lp {
                position: relative
            }

                .mc.lp::before {
                    content: '';
                    position: absolute;
                    inset: -1px;
                    border-radius: inherit;
                    border: 1px solid rgba(255,23,68,.35);
                    animation: pbrd 2s ease-in-out infinite;
                    pointer-events: none
                }
        @@keyframes pbrd {
            0%,100%

        {
            opacity: 1;
            transform: scale(1)
        }

        50% {
            opacity: 0;
            transform: scale(1.012)
        }

        }

        .mc-time {
            flex-shrink: 0;
            width: 74px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 5px;
            padding: 12px 0;
        }

        .mc-min {
            font-family: var(--fd);
            font-size: 15px;
            font-weight: 700;
            color: var(--t2)
        }

            .mc-min.lc {
                color: var(--live)
            }

            .mc-min.bc {
                color: var(--secondary)
            }

            .mc-min.yc {
                color: var(--yellow)
            }

        .sbadge {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            padding: 2px 7px;
            border-radius: 9px;
            white-space: nowrap
        }

        .sb-fin {
            background: rgba(148,163,184,.09);
            color: var(--t3)
        }

        .sb-live {
            background: rgba(255,23,68,.11);
            color: var(--live);
            border: 1px solid rgba(255,23,68,.2);
            display: flex;
            align-items: center;
            gap: 3px
        }

        .sb-up {
            background: rgba(101,31,255,.1);
            color: var(--secondary)
        }

        .sb-ht {
            background: rgba(255,193,7,.1);
            color: var(--yellow)
        }

        .dvv {
            width: 1px;
            height: 44px;
            background: var(--border);
            flex-shrink: 0;
            margin: 0 16px
        }

        .mc-teams {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
        }

        .mc-tr {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 0;
        }

            .mc-tr:first-child {
                border-bottom: 1px solid rgba(255,255,255,.04)
            }

        .tl-sm {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--elevated);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            color: var(--t2);
            flex-shrink: 0;
            overflow: hidden
        }

            .tl-sm img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 3px
            }

        .tn {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 700;
            letter-spacing: .2px;
            flex: 1;
            min-width: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ts {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900;
            color: var(--t1);
            min-width: 26px;
            text-align: right;
            flex-shrink: 0;
        }

            .ts.win {
                color: var(--primary)
            }

            .ts.dim {
                font-size: 15px;
                color: var(--t3)
            }

        .det-btn {
            flex-shrink: 0;
            margin-left: 16px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(101,31,255,.08);
            border: 1px solid rgba(101,31,255,.2);
            color: var(--secondary);
            border-radius: var(--r1);
            padding: 6px 13px;
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--tr);
            white-space: nowrap;
        }

            .det-btn:hover {
                background: rgba(101,31,255,.18);
                color: var(--secondary)
            }

        /* ─── FOOTER ─── */
        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 36px
        }

        .ft-brand {
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px
        }

            .ft-brand span {
                color: var(--primary)
            }

        .ft-desc {
            font-size: 12px;
            color: var(--t3);
            line-height: 1.7;
            max-width: 240px
        }

        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px
        }

        .ft-ul {
            list-style: none;
            padding: 0
        }

            .ft-ul li {
                margin-bottom: 7px
            }

            .ft-ul a {
                color: var(--t3);
                font-size: 12px;
                transition: var(--tr)
            }

                .ft-ul a:hover {
                    color: var(--t1)
                }

        .si-row {
            display: flex;
            gap: 7px;
            margin-top: 14px
        }

        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px
        }

            .si:hover {
                background: var(--elevated);
                color: var(--primary);
                border-color: var(--primary)
            }

        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px
        }

        /* ─── RESPONSIVE ─── */
        @@media(max - width:600px) {
            .tn

        {
            font-size: 13px
        }

        .ts {
            font-size: 18px
        }

        .mc-time {
            width: 60px
        }

        .dvv {
            margin: 0 10px
        }

        .det-btn {
            padding: 5px 8px;
            font-size: 9px
        }

            .det-btn span {
                display: none
            }

        .feat-card {
            padding: 20px 14px
        }

        .ft-logo {
            width: 52px;
            height: 52px
        }

        .ft-name {
            font-size: 14px
        }

        .ft-sc {
            font-size: 44px
        }

        .lg-stats {
            display: none
        }

        }
    </style>
</head>
<body>

    <nav class="nb">
        <div class="nb-inner">
            <a href="/Default/Index/" class="brand">
                <div class="brand-ico">⚽</div>
                <span class="brand-txt">Goal<span>Zone</span></span>
            </a>
            <div class="nav-links d-none d-lg-flex">
                <a href="/Default/Index/" class="nl active">Ana Sayfa</a>
                <a href="#" class="nl">Canlı Skorlar</a>
                <a href="/Fixture/Index/" class="nl">Fikstür</a>
                <a href="/Standings/StandingList/" class="nl">Puan Durumu</a>
                <a href="#" class="nl">Ligler</a>
            </div>
            <div class="nb-icons">
                <a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-search"></i></a>
                <a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-bell"></i></a>
                <a href="#" class="ico-btn"><i class="bi bi-person"></i></a>
                <button class="tog d-lg-none" id="tog"><i class="bi bi-list"></i></button>
            </div>
        </div>
        <div class="mob-menu" id="mobMenu">
            <div class="wrap">
                <a href="/Default/Index/" class="nl d-block active">Ana Sayfa</a>
                <a href="#" class="nl d-block">Canlı Skorlar</a>
                <a href="/Fixture/Index/" class="nl d-block">Fikstür</a>
                <a href="/Standings/StandingList/" class="nl d-block">Puan Durumu</a>
                <a href="#" class="nl d-block">Ligler</a>
            </div>
        </div>
    </nav>

    <section class="lg-head">
        <div class="wrap">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <div class="lg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div>
                    <h1 class="lg-title">Hafta <span style="color:var(--primary)">@Model.SelectedWeek</span> Sonuçları</h1>
                    <p class="lg-sub">Lig Heyecanı &nbsp;·&nbsp; @Model.TotalMatchCount Maç</p>
                </div>
                <div class="col-lg-5 d-none d-lg-block">
                    <div class="lg-stats">
                        <div style="text-align:center"><div class="ls-num">@Model.LiveCount</div><div class="ls-lbl">Canlı</div></div>
                        <div style="text-align:center"><div class="ls-num">@Model.FinishedCount</div><div class="ls-lbl">Biten</div></div>
                        <div style="text-align:center"><div class="ls-num">@Model.UpcomingCount</div><div class="ls-lbl">Yaklaşan</div></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="ftabs-wrap">
        <div class="wrap">
            <div class="ftabs">
                <button class="ftab active" data-f="all">Tüm Maçlar</button>
                <button class="ftab" data-f="live"><span class="live-dot"></span>Canlı<span class="bcnt">@Model.LiveCount</span></button>
                <button class="ftab" data-f="finished">Tamamlananlar</button>
                <button class="ftab" data-f="upcoming">Yaklaşanlar</button>
            </div>
        </div>
    </div>

    <main>
        <div class="wrap" style="padding-top:28px;padding-bottom:56px">

            @if (Model.featuredMatch != null)
            {
                <div class="feat-wrap" id="featWrap">
                    <div class="feat-lbl">Öne Çıkan Maç</div>
                    <a href="/Fixture/GetDetail/@Model.featuredMatch.FixtureId" class="feat-card">
                        <div class="row align-items-center g-2">
                            <div class="col-5">
                                <div class="ft-team">
                                    <div class="ft-logo" style="border-color:rgba(239,1,7,.4)">
                                        <img src="@Model.featuredMatch.HomeLogoUrl" alt="@Model.featuredMatch.HomeTeamName" onerror="this.parentNode.textContent='EVS'" />
                                    </div>
                                    <div class="ft-name">@Model.featuredMatch.HomeTeamName</div>
                                    <div class="ft-type">Ev Sahibi</div>
                                </div>
                            </div>
                            <div class="col-2 text-center">
                                <div class="ft-sc-area">
                                    <div class="ft-sc">@Model.featuredMatch.FullTimeHomeScore – @Model.featuredMatch.FullTimeAwayScore</div>
                                    <div class="ft-stat"><i class="bi bi-check2-circle"></i> MAÇ BİTTİ</div>
                                    <div class="ft-meta">İY: @Model.featuredMatch.HalfTimeHomeScore–@Model.featuredMatch.HalfTimeAwayScore &nbsp;·&nbsp; @Model.featuredMatch.MatchDate.ToString("HH:mm")</div>
                                </div>
                            </div>
                            <div class="col-5">
                                <div class="ft-team">
                                    <div class="ft-logo" style="border-color:rgba(200,16,46,.4)">
                                        <img src="@Model.featuredMatch.AwayLogoUrl" alt="@Model.featuredMatch.AwayTeamName" onerror="this.parentNode.textContent='DEP'" />
                                    </div>
                                    <div class="ft-name">@Model.featuredMatch.AwayTeamName</div>
                                    <div class="ft-type">Deplasman</div>
                                </div>
                            </div>
                        </div>
                        <div class="text-center mt-3" style="font-size:12px;color:var(--t2)">
                            <i class="bi bi-geo-alt"></i> @Model.featuredMatch.StadiumName &nbsp;·&nbsp;
                            <i class="bi bi-calendar3"></i> @Model.featuredMatch.MatchDate.ToString("dd MMMM yyyy") &nbsp;·&nbsp;
                            <span style="color:var(--secondary)">Detayları Gör →</span>
                        </div>
                    </a>
                </div>
            }

            <div class="sec-ttl mcw-section" data-s="live">🔴 &nbsp;Canlı Maçlar</div>
            @foreach (var item in Model.LiveMatches)
            {
                <div class="mc-wrap mcw" data-s="live">
                    <div class="mc live lp">
                        <div class="mc-time">
                            <div class="mc-min lc">@random.Next(1, 90)'</div>
                            <div class="sbadge sb-live"><span class="live-dot"></span>CANLI</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                <div class="tl-sm"><img src="@item.HomeLogoUrl" alt="@item.HomeTeamName" onerror="this.parentNode.textContent='---'" /></div>
                                <span class="tn">@item.HomeTeamName</span>
                                <span class="ts">@item.FullTimeHomeScore</span>
                            </div>
                            <div class="mc-tr">
                                <div class="tl-sm"><img src="@item.AwayLogoUrl" alt="@item.AwayTeamName" onerror="this.parentNode.textContent='---'" /></div>
                                <span class="tn">@item.AwayTeamName</span>
                                <span class="ts">@item.FullTimeAwayScore</span>
                            </div>
                        </div>
                        <a href="/Fixture/GetDetail/@item.FixtureId" class="det-btn"><i class="bi bi-chevron-right"></i> <span>Detay</span></a>
                    </div>
                </div>
            }
            @if (!Model.LiveMatches.Any())
            {
                <div style="color:var(--t3);font-family:var(--fd);padding:16px;text-align:center;">
                    Bu haftada canlı maç bulunmuyor.
                </div>
            }

            <div class="sec-ttl mcw-section" data-s="finished" style="margin-top:22px">✅ &nbsp;Tamamlanan Maçlar</div>
            @foreach (var item in Model.FinishedMatches)
            {
                <div class="mc-wrap mcw" data-s="finished">
                    <a href="/Fixture/GetDetail/@item.FixtureId" class="mc">
                        <div class="mc-time">
                            <div class="mc-min">@item.MatchDate.ToString("HH:mm")</div>
                            <div class="sbadge sb-fin">MS</div>
                        </div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                <div class="tl-sm"><img src="@item.HomeLogoUrl" alt="@item.HomeTeamName" onerror="this.parentNode.textContent='---'" /></div>
                                <span class="tn">@item.HomeTeamName</span><span class="ts">@item.FullTimeHomeScore</span>
                            </div>
                            <div class="mc-tr">
                                <div class="tl-sm"><img src="@item.AwayLogoUrl" alt="@item.AwayTeamName" onerror="this.parentNode.textContent='---'" /></div>
                                <span class="tn">@item.AwayTeamName</span><span class="ts">@item.FullTimeAwayScore</span>
                            </div>
                        </div>
                        <a href="/Fixture/GetDetail/@item.FixtureId" class="det-btn"><i class="bi bi-chevron-right"></i> <span>Detay</span></a>
                    </a>
                </div>
            }
            @if (!Model.FinishedMatches.Any())
            {
                <div style="color:var(--t3);font-family:var(--fd);padding:16px;text-align:center;">
                    Bu haftada tamamlanan maç bulunmuyor.
                </div>
            }

            <div class="sec-ttl mcw-section" data-s="upcoming" style="margin-top:22px">🕐 &nbsp;Yaklaşan Maçlar</div>
            @foreach (var item in Model.UpcomingMatches)
            {
                <div class="mc-wrap mcw" data-s="upcoming">
                    <a href="/Fixture/GetDetail/@item.FixtureId" class="mc">
                        <div class="mc-time"><div class="mc-min bc">@item.MatchDate.ToString("HH:mm")</div><div class="sbadge sb-up">@item.MatchDate.ToString("dd MMM")</div></div>
                        <div class="dvv"></div>
                        <div class="mc-teams">
                            <div class="mc-tr">
                                <div class="tl-sm"><img src="@item.HomeLogoUrl" alt="@item.HomeTeamName" onerror="this.parentNode.textContent='---'" /></div>
                                <span class="tn">@item.HomeTeamName</span><span class="ts dim">—</span>
                            </div>
                            <div class="mc-tr">
                                <div class="tl-sm"><img src="@item.AwayLogoUrl" alt="@item.AwayTeamName" onerror="this.parentNode.textContent='---'" /></div>
                                <span class="tn">@item.AwayTeamName</span><span class="ts dim">—</span>
                            </div>
                        </div>
                        <a href="/Fixture/GetDetail/@item.FixtureId" class="det-btn" onclick="return false"><i class="bi bi-calendar-check"></i> <span>Fikstür</span></a>
                    </a>
                </div>
            }

        </div>
    </main>

    <footer class="ft">
        <div class="wrap">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="ft-brand">Goal<span>Zone</span></div>
                    <p class="ft-desc">Futbol liglerinin canlı skorları, maç analizleri ve istatistikleri için tek adres.</p>
                    <div class="si-row">
                        <a href="#" class="si"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="si"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="si"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="si"><i class="bi bi-telegram"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Ligler</div>
                    <ul class="ft-ul">
                        <li><a href="#">Premier League</a></li>
                        <li><a href="#">La Liga</a></li>
                        <li><a href="#">Bundesliga</a></li>
                        <li><a href="#">Serie A</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Hızlı Erişim</div>
                    <ul class="ft-ul">
                        <li><a href="/Default/Index/">Haftalık Skorlar</a></li>
                        <li><a href="/Fixture/Index/">Fikstür</a></li>
                        <li><a href="/Standings/StandingList/">Puan Durumu</a></li>
                        <li><a href="#">Gol Krallığı</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Takımlar</div>
                    <ul class="ft-ul">
                        <li><a href="#">Arsenal</a></li>
                        <li><a href="#">Liverpool</a></li>
                        <li><a href="#">Man City</a></li>
                        <li><a href="#">Chelsea</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Destek</div>
                    <ul class="ft-ul">
                        <li><a href="#">Hakkımızda</a></li>
                        <li><a href="#">İletişim</a></li>
                        <li><a href="#">Gizlilik</a></li>
                        <li><a href="#">Kullanım Şartları</a></li>
                    </ul>
                </div>
            </div>
            <div class="ft-bot">
                <span>© 2026 GoalZone. Tüm hakları saklıdır.</span>
                <span>Proje verileri test amaçlıdır.</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mobile nav
        const tog = document.getElementById('tog');
        const mob = document.getElementById('mobMenu');
        tog.addEventListener('click', () => {
          mob.classList.toggle('open');
          tog.innerHTML = mob.classList.contains('open')
            ? '<i class="bi bi-x-lg"></i>' : '<i class="bi bi-list"></i>';
        });

        // Navbar shadow
        window.addEventListener('scroll', () => {
          document.querySelector('.nb').style.boxShadow =
            window.scrollY > 8 ? '0 4px 32px rgba(0,0,0,.7)' : '0 2px 24px rgba(0,0,0,.5)';
        });

        // Filter tabs
        document.querySelectorAll('.ftab').forEach(tab => {
          tab.addEventListener('click', () => {
            document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            const f = tab.dataset.f;

            document.querySelectorAll('.mcw').forEach(w => {
              w.style.display = (f === 'all' || w.dataset.s === f) ? 'block' : 'none';
            });
            document.querySelectorAll('.mcw-section').forEach(s => {
              s.style.display = (f === 'all' || s.dataset.s === f) ? 'block' : 'none';
            });
            document.getElementById('featWrap').style.display = f === 'all' ? 'block' : 'none';
          });
        });
    </script>
</body>
</html>