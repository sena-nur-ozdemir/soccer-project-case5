@using SoccerProjectCase5.WebUI.Dtos.FixtureDtos
@using SoccerProjectCase5.WebUI.Dtos.MatchEventDtos
@using SoccerProjectCase5.WebUI.Dtos.MatchStatisticDtos
@using SoccerProjectCase5.WebUI.Models.Enums
@model GetFixtureByIdDto
@{
    Layout = null;
}
@{
    var events = Model.MatchEvents ?? new List<MatchEventDto>();

    // 1. Goller Kutusu: Normal Gol ve Penaltı Golü
    var goals = events.Where(x => x.EventType == MatchEventType.Goal ||
                                  x.EventType == MatchEventType.PenaltyGoal).ToList();

    // 2. Kartlar Kutusu: Sarı Kart, Kırmızı Kart ve İkinci Sarıdan Kırmızı
    var cards = events.Where(x => x.EventType == MatchEventType.YellowCard ||
                                  x.EventType == MatchEventType.RedCard ||
                                  x.EventType == MatchEventType.SecondYellowRed).ToList();

    // 3. Değişiklikler Kutusu: Giren ve Çıkan
    var subs = events.Where(x => x.EventType == MatchEventType.SubstitutionIn ||
                                 x.EventType == MatchEventType.SubstitutionOut).ToList();

    var statusText = Model.Status switch
    {
        MatchStatus.NotPlayed => "Başlamadı",
        MatchStatus.Ongoing => "Devam Ediyor",
        MatchStatus.Ended => "Maç Bitti",
        _ => "Bilinmiyor"
    };
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.HomeTeamName @Model.FullTimeHomeScore–@Model.FullTimeAwayScore @Model.AwayTeamName — GoalZone Maç Detayı</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #0a0f1a;
            --bg2: #0f172a;
            --card: #1e293b;
            --card2: #273449;
            --elevated: #334155;
            --green: #00e5ff; /* Turkuaz */
            --blue: #651fff; /* Mor/İndigo */
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #f8fafc;
            --t2: #94a3b8;
            --t3: #64748b;
            --border: #334155;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --shadow: 0 4px 24px rgba(0,0,0,.5);
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: 'Barlow Condensed',sans-serif;
            --fb: 'Barlow',sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at 15% 0%,rgba(101,31,255,.07) 0%,transparent 55%), radial-gradient(ellipse at 85% 0%,rgba(0,229,255,.04) 0%,transparent 50%)
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: var(--bg)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--elevated);
            border-radius: 3px
        }

        a {
            text-decoration: none;
            color: inherit
        }

        img {
            display: block
        }

        /* ── NAVBAR ── */
        .nb {
            background: rgba(10,15,26,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5)
        }

        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0
        }

        .brand-ico {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg,var(--green),var(--blue));
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px
        }

        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px
        }

            .brand-txt span {
                color: var(--green)
            }

        .nav-links {
            display: flex
        }

        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr)
        }

            .nl::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--green);
                transform: scaleX(0);
                transition: var(--tr)
            }

            .nl:hover, .nl.active {
                color: var(--t1)
            }

                .nl:hover::after, .nl.active::after {
                    transform: scaleX(1)
                }

        .nb-icons {
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr)
        }

            .ico-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1
        }

        .mob-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height .3s ease
        }

            .mob-menu.open {
                max-height: 320px
            }

            .mob-menu .nl {
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                display: block
            }

        /* ── WRAP ── */
        .wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px
        }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(180deg,#0f172a 0%,var(--bg) 100%);
            border-bottom: 1px solid var(--border);
            padding: 36px 0 28px;
            position: relative;
            overflow: hidden
        }

            .hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse at 20% 50%,rgba(0,229,255,.05) 0%,transparent 60%), radial-gradient(ellipse at 80% 50%,rgba(101,31,255,.05) 0%,transparent 60%);
                pointer-events: none
            }

        .hero-badges {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 26px;
            flex-wrap: wrap
        }

        .hbadge {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 4px 12px;
            border-radius: 20px
        }

        .hb-gold {
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.2);
            color: var(--gold)
        }

        .hb-gray {
            background: rgba(148,163,184,.08);
            color: var(--t3)
        }

        .hb-green {
            background: rgba(0,229,255,.08);
            border: 1px solid rgba(0,229,255,.18);
            color: var(--green)
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 20px;
            align-items: center
        }

        .h-team {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px
        }

        .h-logo {
            width: 86px;
            height: 86px;
            border-radius: 50%;
            background: var(--card);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 24px;
            font-weight: 900;
            overflow: hidden
        }

            .h-logo img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 8px
            }

        .h-name {
            font-family: var(--fd);
            font-size: clamp(18px,3vw,26px);
            font-weight: 900;
            letter-spacing: .3px;
            text-align: center
        }

        .h-type {
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600
        }

        .h-score-c {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px
        }

        .h-sc {
            font-family: var(--fd);
            font-size: clamp(54px,10vw,88px);
            font-weight: 900;
            letter-spacing: -4px;
            line-height: 1;
            background: linear-gradient(180deg,#fff 0%,#94a3b8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

        .h-ht {
            font-family: var(--fd);
            font-size: 12px;
            color: var(--t2);
            background: var(--card);
            padding: 4px 14px;
            border-radius: 11px;
            border: 1px solid var(--border)
        }

        .h-ft {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3)
        }

        .info-strip {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 22px;
            margin-top: 22px;
            padding-top: 18px;
            border-top: 1px solid var(--border);
            flex-wrap: wrap
        }

        .istrip {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--t2)
        }

            .istrip i {
                color: var(--t3);
                font-size: 13px
            }

        /* ── CONTENT ── */
        .content {
            padding: 28px 0 56px
        }

        .dc {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r3);
            padding: 22px;
            margin-bottom: 18px
        }

        .dc-title {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t3);
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px
        }

            .dc-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border)
            }

        /* ── TIMELINE ── */
        .tl-wrap {
            position: relative
        }

        .tl-line {
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 1px;
            background: var(--border);
            transform: translateX(-50%)
        }

        .tl-ev {
            display: grid;
            grid-template-columns: 1fr 58px 1fr;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
            animation: fadeUp .4s ease both
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(8px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .tl-home {
            display: flex;
            justify-content: flex-end
        }

        .tl-away {
            display: flex;
            justify-content: flex-start
        }

        .tl-min-c {
            display: flex;
            align-items: center;
            justify-content: center
        }

        .min-b {
            background: var(--elevated);
            border: 1px solid var(--border);
            border-radius: 11px;
            padding: 3px 8px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            color: var(--t2);
            white-space: nowrap;
            position: relative;
            z-index: 1
        }

        .chip {
            display: flex;
            align-items: center;
            gap: 7px;
            background: var(--elevated);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 8px 11px;
            max-width: 220px
        }

            .chip.home {
                flex-direction: row-reverse;
                text-align: right
            }

            /* 10 Aksiyonun Tamamı İçin Özel Renk Kodları */
            .chip.goal-ev {
                border-color: rgba(0,229,255,.25);
                background: rgba(0,229,255,.06)
            }

        .ei-goal {
            background: rgba(0,229,255,.15);
            color: var(--green)
        }

        .chip.ast-ev {
            border-color: rgba(101,31,255,.3);
            background: rgba(101,31,255,.06)
        }

        .ei-ast {
            background: rgba(101,31,255,.18);
            color: #b388ff
        }

        .chip.yel-ev {
            border-color: rgba(255,193,7,.25);
            background: rgba(255,193,7,.06)
        }

        .ei-yel {
            background: rgba(255,193,7,.15);
            color: var(--yellow)
        }

        .chip.red-ev {
            border-color: rgba(244,67,54,.25);
            background: rgba(244,67,54,.06)
        }

        .ei-red {
            background: rgba(244,67,54,.15);
            color: var(--red)
        }

        .chip.syr-ev {
            border-color: rgba(255,109,0,.3);
            background: rgba(255,109,0,.06)
        }

        .ei-syr {
            background: rgba(255,109,0,.18);
            color: #ff6d00
        }

        .chip.sub-ev {
            border-color: rgba(101,31,255,.2);
            background: rgba(101,31,255,.05)
        }

        .ei-sub {
            background: rgba(101,31,255,.12);
            color: var(--blue)
        }

        .chip.mpen-ev {
            border-color: rgba(255,23,68,.3);
            background: rgba(255,23,68,.06)
        }

        .ei-mpen {
            background: rgba(255,23,68,.18);
            color: #ff1744
        }

        .chip.inj-ev {
            border-color: rgba(240,98,146,.3);
            background: rgba(240,98,146,.06)
        }

        .ei-inj {
            background: rgba(240,98,146,.18);
            color: #f06292
        }

        .ev-ico {
            width: 26px;
            height: 26px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            flex-shrink: 0
        }

        .ev-pl {
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700;
            color: var(--t1)
        }

        .ev-dt {
            font-size: 10px;
            color: var(--t3)
        }

        /* ── GOALS / CARDS ── */
        .split2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px
        }

        .box2 {
            padding: 14px;
            background: var(--bg2);
            border-radius: var(--r2);
            border: 1px solid var(--border)
        }

        .box2-title {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3);
            margin-bottom: 10px
        }

        .gl {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 6px 0;
            border-bottom: 1px solid rgba(255,255,255,.04)
        }

            .gl:last-child {
                border-bottom: none
            }

        .gl-ico {
            width: 20px;
            height: 20px;
            background: rgba(0,229,255,.12);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: var(--green);
            flex-shrink: 0
        }

        .gl-pl {
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700;
            flex: 1
        }

        .gl-min {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            color: var(--t3);
            background: var(--elevated);
            padding: 2px 7px;
            border-radius: 7px
        }

        .ycard {
            width: 12px;
            height: 16px;
            background: var(--yellow);
            border-radius: 2px;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(255,193,7,.3)
        }

        .rcard {
            width: 12px;
            height: 16px;
            background: var(--red);
            border-radius: 2px;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(244,67,54,.3)
        }

        /* 2. Sarıdan Kırmızı Kart İçin Çift Renkli Harika Kutu */
        .syr-card {
            width: 12px;
            height: 16px;
            background: linear-gradient(135deg, var(--yellow) 50%, var(--red) 50%);
            border-radius: 2px;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(255,109,0,.3)
        }

        /* ── SUBSTITUTIONS ── */
        .sub-r {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 9px 0;
            border-bottom: 1px solid rgba(255,255,255,.04)
        }

            .sub-r:last-child {
                border-bottom: none
            }

        .sub-min {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            color: var(--t3);
            background: var(--elevated);
            padding: 3px 9px;
            border-radius: 9px;
            width: 46px;
            text-align: center;
            flex-shrink: 0
        }

        .sub-in {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 700;
            color: var(--green)
        }

        .sub-out {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 700;
            color: var(--live)
        }

        .sub-arr {
            color: var(--t3);
            font-size: 15px
        }

        .sub-lbl {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t3);
            margin: 14px 0 6px;
            padding-top: 10px;
            border-top: 1px solid var(--border)
        }

            .sub-lbl:first-child {
                margin-top: 0;
                padding-top: 0;
                border-top: none
            }

        /* ── STATS ── */
        .stat-r {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 10px;
            align-items: center;
            margin-bottom: 12px
        }

        .sv-h {
            font-family: var(--fd);
            font-size: 17px;
            font-weight: 800;
            text-align: right
        }

        .sv-a {
            font-family: var(--fd);
            font-size: 17px;
            font-weight: 800;
            text-align: left
        }

        .sl {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t3);
            text-align: center;
            white-space: nowrap
        }

        .bar-r {
            display: grid;
            grid-template-columns: 1fr 20px 1fr;
            gap: 7px;
            align-items: center;
            margin-bottom: 12px
        }

        .bh {
            height: 3px;
            background: var(--elevated);
            border-radius: 2px;
            overflow: hidden;
            display: flex;
            justify-content: flex-end
        }

            .bh .f {
                height: 100%;
                background: linear-gradient(90deg,var(--blue),#a78bfa);
                border-radius: 2px;
                transition: width 1.1s ease
            }

        .ba {
            height: 3px;
            background: var(--elevated);
            border-radius: 2px;
            overflow: hidden
        }

            .ba .f {
                height: 100%;
                background: linear-gradient(90deg,#ff6b6b,var(--live));
                border-radius: 2px;
                transition: width 1.1s ease
            }

        /* ── MATCH INFO BOX ── */
        .mi-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
            font-size: 13px
        }

            .mi-row:last-child {
                border-bottom: none
            }

        .mi-key {
            color: var(--t3)
        }

        .mi-val {
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700;
            text-align: right
        }

        /* ── SCORE PILLS ── */
        .sc-pills {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 8px;
            margin-bottom: 4px
        }

        .sc-pill {
            background: var(--bg2);
            border-radius: var(--r2);
            padding: 11px;
            text-align: center;
            border: 1px solid var(--border)
        }

        .sp-lbl {
            font-family: var(--fd);
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 3px
        }

        .sp-val {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900
        }

        /* ── BACK BTN ── */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            color: var(--t2);
            padding: 10px 18px;
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: var(--tr);
            margin-bottom: 22px
        }

            .back-btn:hover {
                background: var(--elevated);
                border-color: var(--blue);
                color: var(--t1)
            }

        /* ── FOOTER ── */
        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 36px
        }

        .ft-brand {
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px
        }

            .ft-brand span {
                color: var(--green)
            }

        .ft-desc {
            font-size: 12px;
            color: var(--t3);
            line-height: 1.7;
            max-width: 240px
        }

        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px
        }

        .ft-ul {
            list-style: none;
            padding: 0
        }

            .ft-ul li {
                margin-bottom: 7px
            }

            .ft-ul a {
                color: var(--t3);
                font-size: 12px;
                transition: var(--tr)
            }

                .ft-ul a:hover {
                    color: var(--t1)
                }

        .si-row {
            display: flex;
            gap: 7px;
            margin-top: 14px
        }

        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px
        }

            .si:hover {
                background: var(--elevated);
                color: var(--green);
                border-color: var(--green)
            }

        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px
        }

        /* ── RESPONSIVE ── */
        @@media(max-width:768px) {
            .hero-grid {
                gap: 10px
            }

            .h-logo {
                width: 60px;
                height: 60px
            }

            .h-name {
                font-size: 14px
            }

            .h-sc {
                font-size: 52px;
                letter-spacing: -2px
            }

            .tl-ev {
                grid-template-columns: 1fr 46px 1fr;
                gap: 5px
            }

            .chip {
                padding: 6px 8px;
                max-width: 150px
            }

            .ev-pl {
                font-size: 12px
            }

            .ev-dt {
                display: none
            }

            .ev-ico {
                width: 22px;
                height: 22px;
                font-size: 11px
            }

            .split2 {
                grid-template-columns: 1fr
            }

            .info-strip {
                gap: 12px
            }

            .istrip {
                font-size: 11px
            }

            .sc-pills {
                grid-template-columns: repeat(3,1fr)
            }
        }

        @@media(max-width:480px) {
            .h-sc {
                font-size: 42px
            }

            .h-logo {
                width: 50px;
                height: 50px
            }

            .h-name {
                font-size: 12px
            }

            .info-strip {
                gap: 8px
            }
        }
    </style>
</head>
<body>

    <nav class="nb">
        <div class="nb-inner">
            <a href="/Default/Index/" class="brand">
                <div class="brand-ico">⚽</div>
                <span class="brand-txt">Goal<span>Zone</span></span>
            </a>
            <div class="nav-links d-none d-lg-flex">
                <a href="/Default/Index/" class="nl">Ana Sayfa</a>
                <a href="/Default/Index/" class="nl">Canlı Skorlar</a>
                <a href="/Fixture/Index/" class="nl active">Fikstür</a>
                <a href="/Standings/StandingList/" class="nl">Puan Durumu</a>
                <a href="#" class="nl">Ligler</a>
            </div>
            <div class="nb-icons">
                <a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-search"></i></a>
                <a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-bell"></i></a>
                <a href="#" class="ico-btn"><i class="bi bi-person"></i></a>
                <button class="tog d-lg-none" id="tog"><i class="bi bi-list"></i></button>
            </div>
        </div>
        <div class="mob-menu" id="mobMenu">
            <div class="wrap">
                <a href="/Default/Index/" class="nl d-block">Ana Sayfa</a>
                <a href="/Default/Index/" class="nl d-block">Canlı Skorlar</a>
                <a href="/Fixture/Index/" class="nl d-block active">Fikstür</a>
                <a href="/Standings/StandingList/" class="nl d-block">Puan Durumu</a>
                <a href="#" class="nl d-block">Ligler</a>
            </div>
        </div>
    </nav>

    <section class="hero">
        <div class="wrap">
            <div class="hero-badges">
                <span class="hbadge hb-gold"><i class="bi bi-trophy-fill me-1"></i>Premier League · Hafta @Model.WeekNumber</span>
                <span class="hbadge hb-gray"><i class="bi bi-check2-circle me-1"></i>@statusText</span>
                <span class="hbadge hb-green"><i class="bi bi-people-fill me-1"></i>60,260 Seyirci</span>
            </div>
            <div class="hero-grid">
                <div class="h-team">
                    <div class="h-logo" style="border-color:rgba(239,1,7,.5);box-shadow:0 0 28px rgba(239,1,7,.1)">
                        <img src="@Model.HomeLogoUrl" alt="@Model.HomeTeamName" onerror="this.parentNode.textContent='EVS'" />
                    </div>
                    <div class="h-name">@Model.HomeTeamName</div>
                    <div class="h-type">Ev Sahibi</div>
                </div>
                <div class="h-score-c">
                    <div class="h-sc">@Model.FullTimeHomeScore–@Model.FullTimeAwayScore</div>
                    <div class="h-ht"><i class="bi bi-hourglass-split me-1"></i>İY: @Model.HalfTimeHomeScore–@Model.HalfTimeAwayScore</div>
                    <div class="h-ft">@statusText</div>
                </div>
                <div class="h-team">
                    <div class="h-logo" style="border-color:rgba(200,16,46,.5);box-shadow:0 0 28px rgba(200,16,46,.1)">
                        <img src="@Model.AwayLogoUrl" alt="@Model.AwayTeamName" onerror="this.parentNode.textContent='DEP'" />
                    </div>
                    <div class="h-name">@Model.AwayTeamName</div>
                    <div class="h-type">Deplasman</div>
                </div>
            </div>
            <div class="info-strip">
                <div class="istrip"><i class="bi bi-geo-alt-fill"></i><span>@Model.StadiumName</span></div>
                <div class="istrip"><i class="bi bi-calendar3"></i><span>@Model.MatchDate.ToString("dd MMMM yyyy")</span></div>
                <div class="istrip"><i class="bi bi-clock"></i><span>@Model.MatchDate.ToString("HH:mm")</span></div>
                <div class="istrip"><i class="bi bi-person-badge"></i><span>Michael Oliver</span></div>
            </div>
        </div>
    </section>

    <div class="content">
        <div class="wrap">
            <a href="/Fixture/Index/" class="back-btn"><i class="bi bi-arrow-left"></i> Maç Listesine Dön</a>

            <div class="row g-4">

                <div class="col-lg-7">

                    <div class="dc">
                        <div class="dc-title"><i class="bi bi-activity me-2" style="color:var(--green)"></i>Maç Olayları</div>
                        <div class="tl-wrap">
                            <div class="tl-line"></div>
                            @if (Model.MatchEvents == null || !Model.MatchEvents.Any())
                            {
                                <div class="tl-ev">
                                    <div class="tl-home"></div>
                                    <div class="tl-min-c">
                                        <div class="min-b" style="opacity:.6">Olay yok</div>
                                    </div>
                                    <div class="tl-away"></div>
                                </div>
                            }
                            else
                            {
                                @foreach (var item in Model.MatchEvents.OrderBy(x => x.Minute))
                                {
                                    var isHome = item.TeamId == Model.HomeTeamId;

                                    // 10 Olay Tipinin Tamamı İçin CSS Sınıfları
                                    var chipClass = item.EventType switch
                                    {
                                        MatchEventType.Goal or MatchEventType.PenaltyGoal => "goal-ev",
                                        MatchEventType.Assist => "ast-ev",
                                        MatchEventType.YellowCard => "yel-ev",
                                        MatchEventType.RedCard => "red-ev",
                                        MatchEventType.SecondYellowRed => "syr-ev",
                                        MatchEventType.SubstitutionIn or MatchEventType.SubstitutionOut => "sub-ev",
                                        MatchEventType.MissedPenalty => "mpen-ev",
                                        MatchEventType.Injury => "inj-ev",
                                        _ => ""
                                    };

                                    // 10 Olay Tipinin Tamamı İçin İkonlar
                                    var icon = item.EventType switch
                                    {
                                        MatchEventType.Goal => "bi-circle-fill",
                                        MatchEventType.PenaltyGoal => "bi-record-circle-fill",
                                        MatchEventType.Assist => "bi-stars",
                                        MatchEventType.YellowCard => "bi-square-fill",
                                        MatchEventType.RedCard => "bi-square-fill",
                                        MatchEventType.SecondYellowRed => "bi-copy",
                                        MatchEventType.SubstitutionIn => "bi-arrow-up-right-circle-fill",
                                        MatchEventType.SubstitutionOut => "bi-arrow-down-left-circle-fill",
                                        MatchEventType.MissedPenalty => "bi-x-circle-fill",
                                        MatchEventType.Injury => "bi-bandaid-fill",
                                        _ => "bi-dot"
                                    };

                                    var iconClass = item.EventType switch
                                    {
                                        MatchEventType.Goal or MatchEventType.PenaltyGoal => "ei-goal",
                                        MatchEventType.Assist => "ei-ast",
                                        MatchEventType.YellowCard => "ei-yel",
                                        MatchEventType.RedCard => "ei-red",
                                        MatchEventType.SecondYellowRed => "ei-syr",
                                        MatchEventType.SubstitutionIn or MatchEventType.SubstitutionOut => "ei-sub",
                                        MatchEventType.MissedPenalty => "ei-mpen",
                                        MatchEventType.Injury => "ei-inj",
                                        _ => ""
                                    };

                                    // Açıklama girilmese bile ekranda ne olduğunu net anlatan başlıklar
                                    var eventTitle = item.EventType switch
                                    {
                                        MatchEventType.PenaltyGoal => $"{item.PlayerName} (Penaltı)",
                                        MatchEventType.MissedPenalty => $"{item.PlayerName} (Kaçan Penaltı)",
                                        MatchEventType.SecondYellowRed => $"{item.PlayerName} (2. Sarıdan Kırmızı)",
                                        MatchEventType.Injury => $"{item.PlayerName} (Sakatlık)",
                                        _ => item.PlayerName
                                    };

                                    <div class="tl-ev">
                                        <div class="tl-home">
                                            @if (isHome)
                                            {
                                                <div class="chip home @chipClass">
                                                    <div class="ev-ico @iconClass">
                                                        <i class="bi @icon" style="font-size:11px"></i>
                                                    </div>
                                                    <div>
                                                        <div class="ev-pl">@eventTitle</div>
                                                        @if (!string.IsNullOrEmpty(item.EventDescription))
                                                        {
                                                            <div class="ev-dt">@item.EventDescription</div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        <div class="tl-min-c">
                                            <div class="min-b">@item.Minute'</div>
                                        </div>

                                        <div class="tl-away">
                                            @if (!isHome)
                                            {
                                                <div class="chip away @chipClass">
                                                    <div class="ev-ico @iconClass">
                                                        <i class="bi @icon" style="font-size:11px"></i>
                                                    </div>
                                                    <div>
                                                        <div class="ev-pl">@eventTitle</div>
                                                        @if (!string.IsNullOrEmpty(item.EventDescription))
                                                        {
                                                            <div class="ev-dt">@item.EventDescription</div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="dc">
                        <div class="dc-title"><i class="bi bi-circle-fill me-2" style="color:var(--green);font-size:9px"></i>Goller</div>
                        <div class="split2">
                            <div class="box2">
                                <div class="box2-title">⚽ @Model.HomeTeamName</div>
                                @foreach (var g in goals.Where(x => x.TeamId == Model.HomeTeamId))
                                {
                                    <div class="gl">
                                        <div class="gl-ico">@(g.EventType == MatchEventType.PenaltyGoal ? "🎯" : "⚽")</div>
                                        <div class="gl-pl">
                                            @g.PlayerName
                                            @if (g.EventType == MatchEventType.PenaltyGoal)
                                            {
                                                <span style="font-size:10px;color:var(--green) me-1">(Penaltı)</span>
                                            }
                                        </div>
                                        <div class="gl-min">@g.Minute'</div>
                                    </div>
                                }
                                @if (!goals.Any(x => x.TeamId == Model.HomeTeamId))
                                {
                                    <div class="gl" style="opacity:.6">Gol yok</div>
                                }
                            </div>
                            <div class="box2">
                                <div class="box2-title">⚽ @Model.AwayTeamName</div>
                                @foreach (var g in goals.Where(x => x.TeamId == Model.AwayTeamId))
                                {
                                    <div class="gl">
                                        <div class="gl-ico">@(g.EventType == MatchEventType.PenaltyGoal ? "🎯" : "⚽")</div>
                                        <div class="gl-pl">
                                            @g.PlayerName
                                            @if (g.EventType == MatchEventType.PenaltyGoal)
                                            {
                                                <span style="font-size:10px;color:var(--green) me-1">(Penaltı)</span>
                                            }
                                        </div>
                                        <div class="gl-min">@g.Minute'</div>
                                    </div>
                                }
                                @if (!goals.Any(x => x.TeamId == Model.AwayTeamId))
                                {
                                    <div class="gl" style="opacity:.6">Gol yok</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="dc">
                        <div class="dc-title"><i class="bi bi-square-fill me-2" style="color:var(--yellow);font-size:10px"></i>Kartlar</div>
                        <div class="split2">
                            <div class="box2">
                                <div class="box2-title">@Model.HomeTeamName</div>
                                @foreach (var c in cards.Where(x => x.TeamId == Model.HomeTeamId))
                                {
                                    var cardClass = c.EventType switch
                                    {
                                        MatchEventType.RedCard => "rcard",
                                        MatchEventType.SecondYellowRed => "syr-card",
                                        _ => "ycard"
                                    };

                                    <div class="gl">
                                        <div class="@cardClass"></div>
                                        <div class="gl-pl">
                                            @c.PlayerName
                                            @if (c.EventType == MatchEventType.SecondYellowRed)
                                            {
                                                <span style="font-size:10px;color:var(--red) ms-1">(2. Sarı)</span>
                                            }
                                        </div>
                                        <div class="gl-min">@c.Minute'</div>
                                    </div>
                                }
                                @if (!cards.Any(x => x.TeamId == Model.HomeTeamId))
                                {
                                    <div class="gl" style="opacity:.6">Kart yok</div>
                                }
                            </div>
                            <div class="box2">
                                <div class="box2-title">@Model.AwayTeamName</div>
                                @foreach (var c in cards.Where(x => x.TeamId == Model.AwayTeamId))
                                {
                                    var cardClass = c.EventType switch
                                    {
                                        MatchEventType.RedCard => "rcard",
                                        MatchEventType.SecondYellowRed => "syr-card",
                                        _ => "ycard"
                                    };

                                    <div class="gl">
                                        <div class="@cardClass"></div>
                                        <div class="gl-pl">
                                            @c.PlayerName
                                            @if (c.EventType == MatchEventType.SecondYellowRed)
                                            {
                                                <span style="font-size:10px;color:var(--red) ms-1">(2. Sarı)</span>
                                            }
                                        </div>
                                        <div class="gl-min">@c.Minute'</div>
                                    </div>
                                }
                                @if (!cards.Any(x => x.TeamId == Model.AwayTeamId))
                                {
                                    <div class="gl" style="opacity:.6">Kart yok</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="dc">
                        <div class="dc-title"><i class="bi bi-arrow-left-right me-2" style="color:var(--blue)"></i>Oyuncu Değişiklikleri</div>
                        <div class="sub-lbl">@Model.HomeTeamName</div>
                        @if (subs.Any(x => x.TeamId == Model.HomeTeamId))
                        {
                            foreach (var s in subs.Where(x => x.TeamId == Model.HomeTeamId))
                            {
                                <div class="sub-r">
                                    <div class="sub-min">@s.Minute'</div>
                                    <div class="sub-in">↑ @s.PlayerName</div><div class="sub-arr">⇄</div><div class="sub-out">↓ @s.EventDescription</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sub-r" style="opacity:.6">Değişiklik yok</div>
                        }

                        <div class="sub-lbl">@Model.AwayTeamName</div>
                        @if (subs.Any(x => x.TeamId == Model.AwayTeamId))
                        {
                            foreach (var s in subs.Where(x => x.TeamId == Model.AwayTeamId))
                            {
                                <div class="sub-r">
                                    <div class="sub-min">@s.Minute'</div>
                                    <div class="sub-in">↑ @s.PlayerName</div><div class="sub-arr">⇄</div><div class="sub-out">↓ @s.EventDescription</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sub-r" style="opacity:.6">Değişiklik yok</div>
                        }
                    </div>

                </div>

                <div class="col-lg-5">

                    <div class="dc">
                        <div class="dc-title"><i class="bi bi-bar-chart-fill me-2" style="color:var(--blue)"></i>Maç Özeti</div>
                        <div class="sc-pills">
                            <div class="sc-pill"><div class="sp-lbl">İlk Yarı</div><div class="sp-val">@Model.HalfTimeHomeScore–@Model.HalfTimeAwayScore</div></div>
                            <div class="sc-pill">
                                <div class="sp-lbl">İkinci Yarı</div><div class="sp-val">
                                    @(Model.FullTimeHomeScore - Model.HalfTimeHomeScore) – @(Model.FullTimeAwayScore - Model.HalfTimeAwayScore)
                                </div>
                            </div>
                            <div class="sc-pill"><div class="sp-lbl">Sonuç</div><div class="sp-val" style="color:var(--green)">@Model.FullTimeHomeScore–@Model.FullTimeAwayScore</div></div>
                        </div>
                    </div>

                    @if (Model.MatchStatisticDto == null)
                    {
                        <div class="dc">
                            <div class="dc-title"><i class="bi bi-graph-up me-2" style="color:var(--green)"></i>İstatistikler</div>
                            <div style="padding:20px;text-align:center;color:var(--t3)">Maç istatistikleri mevcut değil.</div>
                        </div>
                    }
                    else
                    {
                        <div class="dc">
                            <div class="dc-title"><i class="bi bi-graph-up me-2" style="color:var(--green)"></i>İstatistikler</div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.PossessionHome%</div><div class="sl">Topa Sahip Olma</div><div class="sv-a">@Model.MatchStatisticDto.PossessionAway%</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@Model.MatchStatisticDto.PossessionHome%"></div></div><div></div><div class="ba"><div class="f" style="width:@Model.MatchStatisticDto.PossessionAway%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.ShotsHome</div><div class="sl">Şut</div><div class="sv-a">@Model.MatchStatisticDto.ShotsAway</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@(Model.MatchStatisticDto.ShotsHome * 5)%"></div></div><div></div><div class="ba"><div class="f" style="width:@(Model.MatchStatisticDto.ShotsAway * 5)%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.ShotsOnTargetHome</div><div class="sl">İsabetli Şut</div><div class="sv-a">@Model.MatchStatisticDto.ShotsOnTargetAway</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@(Model.MatchStatisticDto.ShotsOnTargetHome * 5)%"></div></div><div></div><div class="ba"><div class="f" style="width:@(Model.MatchStatisticDto.ShotsOnTargetAway * 5)%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.PassesHome</div><div class="sl">Pas</div><div class="sv-a">@Model.MatchStatisticDto.PassesAway</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@(Model.MatchStatisticDto.PassesHome / 10)%"></div></div><div></div><div class="ba"><div class="f" style="width:@(Model.MatchStatisticDto.PassesAway / 10)%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.PassAccuracyHome%</div><div class="sl">Pas İsabeti</div><div class="sv-a">@Model.MatchStatisticDto.PassAccuracyAway%</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@Model.MatchStatisticDto.PassAccuracyHome%"></div></div><div></div><div class="ba"><div class="f" style="width:@Model.MatchStatisticDto.PassAccuracyAway%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.CornersHome</div><div class="sl">Korner</div><div class="sv-a">@Model.MatchStatisticDto.CornersAway</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@(Model.MatchStatisticDto.CornersHome * 10)%"></div></div><div></div><div class="ba"><div class="f" style="width:@(Model.MatchStatisticDto.CornersAway * 10)%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.FoulsHome</div><div class="sl">Faul</div><div class="sv-a">@Model.MatchStatisticDto.FoulsAway</div></div>
                            <div class="bar-r"><div class="bh"><div class="f" style="width:@(Model.MatchStatisticDto.FoulsHome * 5)%"></div></div><div></div><div class="ba"><div class="f" style="width:@(Model.MatchStatisticDto.FoulsAway * 5)%"></div></div></div>

                            <div class="stat-r"><div class="sv-h">@Model.MatchStatisticDto.OffsidesHome</div><div class="sl">Ofsayt</div><div class="sv-a">@Model.MatchStatisticDto.OffsidesAway</div></div>
                            <div class="bar-r" style="margin-bottom:14px"><div class="bh"><div class="f" style="width:@(Model.MatchStatisticDto.OffsidesHome * 15)%"></div></div><div></div><div class="ba"><div class="f" style="width:@(Model.MatchStatisticDto.OffsidesAway * 15)%"></div></div></div>

                            <div class="stat-r" style="margin-bottom:0">
                                <div class="sv-h" style="color:var(--yellow)">@Model.MatchStatisticDto.YellowCardsHome</div>
                                <div class="sl">Sarı Kart</div>
                                <div class="sv-a" style="color:var(--yellow)">@Model.MatchStatisticDto.YellowCardsAway</div>
                            </div>
                            <div class="stat-r" style="margin-bottom:0;margin-top:8px">
                                <div class="sv-h" style="color:var(--red)">@Model.MatchStatisticDto.RedCardsHome</div>
                                <div class="sl">Kırmızı Kart</div>
                                <div class="sv-a" style="color:var(--t3)">@Model.MatchStatisticDto.RedCardsAway</div>
                            </div>

                            <div style="display:flex;justify-content:space-between;margin-top:18px;padding-top:14px;border-top:1px solid var(--border)">
                                <div style="display:flex;align-items:center;gap:7px">
                                    <div style="width:9px;height:9px;border-radius:50%;background:var(--blue)"></div>
