    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mobile nav
        const tog = document.getElementById('tog');
        const mob = document.getElementById('mobMenu');
        tog.addEventListener('click', () => {
          mob.classList.toggle('open');
          tog.innerHTML = mob.classList.contains('open')
            ? '<i class="bi bi-x-lg"></i>' : '<i class="bi bi-list"></i>';
        });

        // Navbar shadow
        window.addEventListener('scroll', () => {
          document.querySelector('.nb').style.boxShadow =
            window.scrollY > 8 ? '0 4px 32px rgba(0,0,0,.7)' : '0 2px 24px rgba(0,0,0,.5)';
        });

        // Stat bar animation on scroll
        function animateBars() {
          const bars = document.querySelectorAll('.bh .f, .ba .f');
          const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                e.target.style.width = e.target.dataset.w;
                obs.unobserve(e.target);
              }
            });
          }, {threshold: 0.3});
          bars.forEach(b => {
            b.dataset.w = b.style.width;
            b.style.width = '0';
            obs.observe(b);
          });
        }
        animateBars();
    </script>
