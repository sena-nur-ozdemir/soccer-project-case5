@using SoccerProjectCase5.WebUI.Dtos.FixtureDtos
@model CreateFixtureDto

@{
    ViewData["Title"] = "Maç Ekle";
    ViewData["ActivePage"] = "Fixtures";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4 pb-3 border-bottom border-secondary border-opacity-25">
    <i class="bi bi-calendar-plus fs-2 text-info me-3"></i>
    <div>
        <h4 class="fw-bold mb-0 text-white">Maç Ekle</h4>
        <p class="small mb-0" style="color: #94a3b8;">GoalZone fikstürüne yeni bir maç kaydı ekleyin.</p>
    </div>
</div>

<div class="admin-card border border-secondary border-opacity-25 shadow-sm p-4 rounded-4" style="background-color: #151e32;">
    <h5 class="fw-bold text-white mb-4"><i class="bi bi-info-circle me-2 text-info"></i>Maç Bilgileri</h5>

    <form method="post">
        @Html.AntiForgeryToken()

        <h6 class="fw-bold text-uppercase mb-3" style="color: #e2e8f0; letter-spacing: 0.5px;">1. Takımlar</h6>
        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <label asp-for="HomeTeamId" class="form-label fw-bold text-white mb-2">Ev Sahibi Takım <span class="text-danger">*</span></label>
                <select asp-for="HomeTeamId" asp-items="ViewBag.Teams" id="homeTeamSelect" class="form-select py-2 border-secondary bg-dark text-white">
                    <option value="">— Takım seçin —</option>
                </select>
                <span asp-validation-for="HomeTeamId" class="text-danger small mt-1 d-block"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="AwayTeamId" class="form-label fw-bold text-white mb-2">Deplasman Takımı <span class="text-danger">*</span></label>
                <select asp-for="AwayTeamId" asp-items="ViewBag.Teams" id="awayTeamSelect" class="form-select py-2 border-secondary bg-dark text-white">
                    <option value="">— Takım seçin —</option>
                </select>
                <span asp-validation-for="AwayTeamId" class="text-danger small mt-1 d-block"></span>
            </div>
        </div>

        <h6 class="fw-bold text-uppercase mb-3 mt-4" style="color: #e2e8f0; letter-spacing: 0.5px;">2. Skor Bilgileri</h6>
        <div class="row g-4 mb-5 p-4 rounded-3 border border-secondary border-opacity-25" style="background-color: #0b1120;">
            <div class="col-md-3">
                <label asp-for="HalfTimeHomeScore" class="form-label fw-bold text-white mb-2">Ev Sahibi (İlk Yarı)</label>
                <input asp-for="HalfTimeHomeScore" type="number" min="0" max="20" placeholder="0" class="form-control py-2 text-center border-secondary bg-dark text-white" />
                <span asp-validation-for="HalfTimeHomeScore" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="HalfTimeAwayScore" class="form-label fw-bold text-white mb-2">Deplasman (İlk Yarı)</label>
                <input asp-for="HalfTimeAwayScore" type="number" min="0" max="20" placeholder="0" class="form-control py-2 text-center border-secondary bg-dark text-white" />
                <span asp-validation-for="HalfTimeAwayScore" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="FullTimeHomeScore" class="form-label fw-bold text-info mb-2">Ev Sahibi (Maç Sonu)</label>
                <input asp-for="FullTimeHomeScore" type="number" min="0" max="20" placeholder="0" class="form-control py-2 text-center border-info bg-dark text-white" />
                <span asp-validation-for="FullTimeHomeScore" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="FullTimeAwayScore" class="form-label fw-bold text-info mb-2">Deplasman (Maç Sonu)</label>
                <input asp-for="FullTimeAwayScore" type="number" min="0" max="20" placeholder="0" class="form-control py-2 text-center border-info bg-dark text-white" />
                <span asp-validation-for="FullTimeAwayScore" class="text-danger small"></span>
            </div>
        </div>

        <h6 class="fw-bold text-uppercase mb-3 mt-4" style="color: #e2e8f0; letter-spacing: 0.5px;">3. Maç Detayları</h6>
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <label asp-for="StadiumName" class="form-label fw-bold text-white mb-2">Stadyum <span class="text-danger">*</span></label>
                <input asp-for="StadiumName" type="text" placeholder="örn. Anfield" class="form-control py-2 border-secondary bg-dark text-white" />
                <span asp-validation-for="StadiumName" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="MatchDate" class="form-label fw-bold text-white mb-2">Maç Tarihi ve Saati <span class="text-danger">*</span></label>
                <input asp-for="MatchDate" type="datetime-local" class="form-control py-2 border-secondary bg-dark text-white" />
                <span asp-validation-for="MatchDate" class="text-danger small"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="WeekNumber" class="form-label fw-bold text-white mb-2">Hafta <span class="text-danger">*</span></label>
                <input asp-for="WeekNumber" type="number" min="1" max="38" placeholder="28" class="form-control py-2 border-secondary bg-dark text-white" />
                <span asp-validation-for="WeekNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Status" class="form-label fw-bold text-white mb-2">Durum <span class="text-danger">*</span></label>
                <select asp-for="Status" class="form-select py-2 border-secondary bg-dark text-white">
                    <option value="">— Seçin —</option>
                    <option value="0">Oynanmadı</option>
                    <option value="1">Oynanıyor</option>
                    <option value="2">Bitti</option>
                </select>
                <span asp-validation-for="Status" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3 border-top border-secondary border-opacity-25 pt-4">
            <a href="/Admin/Dashboard" class="btn btn-outline-light px-4 py-2">İptal</a>
            <button type="submit" class="btn btn-info px-5 py-2 fw-bold text-dark">
                <i class="bi bi-check-lg me-1"></i> Maç Ekle
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const home = document.getElementById('homeTeamSelect');
        const away = document.getElementById('awayTeamSelect');
        [home, away].forEach(sel => sel.addEventListener('change', () => {
            if (home.value && away.value && home.value === away.value) {
                alert('Ev sahibi ve deplasman takımı aynı olamaz.');
                sel.value = '';
            }
        }));
    </script>
}